{
  "expo": {
    "name": "KEATS Calc",
    "slug": "keats-calc",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kskoba.keatstime",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.kskoba.keatscalc"
    },
    "updates": {
      "url": "https://u.expo.dev/75f03fe9-b658-423d-b785-486a5967f8ef"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-asset",
      "expo-updates"
    ],
    "extra": {
      "eas": {
        "projectId": "75f03fe9-b658-423d-b785-486a5967f8ef"
      }
    }
  }
}
